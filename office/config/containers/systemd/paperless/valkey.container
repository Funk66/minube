# vim: ft=systemd

[Unit]
Description=Valkey broker

[Container]
Pod=paperless.pod
ContainerName=valkey
Image=docker.io/valkey/valkey:8
HealthCmd="/usr/local/bin/valkey-cli ping || exit 1"
HealthStartPeriod=30s
HealthInterval=10s
HealthTimeout=5s
HealthRetries=5
Notify=healthy
Volume=valkey:/data
Label="io.containers.autoupdate=registry"

[Service]
Restart=always