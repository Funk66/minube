# vim: ft=systemd

[Unit]
Description=Database

[Container]
Pod=dawarich.pod
ContainerName=postgis
Image=docker.io/postgis/postgis:17-3.5-alpine
Volume=%S/dawarich/db:/var/lib/postgresql/data:Z
EnvironmentFile=%E/dawarich/env
Environment=POSTGRES_USER=dawarich
Environment=POSTGRES_DB=dawarich
ShmSize=1g
HealthCmd=pg_isready -U dawarich
HealthStartPeriod=5s
HealthInterval=10s
HealthTimeout=10s
HealthRetries=5
Notify=healthy
Label="io.containers.autoupdate=registry"

[Service]
Restart=always
