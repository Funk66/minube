# vim: ft=systemd

[Unit]
Description=Valkey

[Container]
Pod=immich.pod
ContainerName=valkey9
Image=docker.io/valkey/valkey:9
HealthCmd="/usr/local/bin/valkey-cli ping || exit 1"
HealthStartPeriod=30s
HealthInterval=10s
HealthTimeout=5s
HealthRetries=5
Notify=healthy
Volume=valkey9:/data
Label="io.containers.autoupdate=registry"

[Service]
Restart=always
