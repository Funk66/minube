# vim: set ft=caddy:
{
	email admin@guirao.net
	admin :2019
	metrics {
		per_host
	}
	log {
		output file /var/log/caddy/server.log
	}
}

(public) {
	@blockedPaths {
		path *.php
		path */.git*
		path */.env*
		path */db.sqlite3*
		path */.htaccess*
	}
	log_skip @blockedPaths
	abort @blockedPaths

	@disallowed {
		header_regexp User-Agent "(?i)(bot|crawler|spider|scrap(er|y)|scan(ner)?|fetch|monitor|http[-_ ]?client|libwww|wget|python|java|go-http|ruby|perl|nikto|nmap|zgrab|censys|shodan|leakix|netcraft|semrush|ahrefs|mj12|palo alto|expanse|cypex|visionheight|rootevidence|assetnote|iaudit|headlesschrome|dart|aiohttp|req/v)"
		not header_regexp User-Agent (?i)(immich|applecoremedia|cfnetwork|networkingextension)
		not header_regexp User-Agent ^Mozilla/5\.0 .*(Gecko|AppleWebKit).*(Firefox|Chrome|Safari|Edg|OPR)/[0-9]
	}
	log_skip @disallowed
	abort @disallowed
}

(private) {
	bind 10.100.0.1
	tls /data/letsencrypt/live/private/fullchain.pem /data/letsencrypt/live/private/privkey.pem
}

guirao.net {
	redir https://guillermo.guirao.net{uri} permanent
}

photos.guirao.net {
	log {
		output file /var/log/caddy/immich.log
	}
	handle /api/server/ping {
		reverse_proxy host.containers.internal:2283
	}
	handle {
		import public
		reverse_proxy host.containers.internal:2283
	}
}

bulwark.guirao.net {
	log {
		output file /var/log/caddy/bulwark.log
	}
	import public
	reverse_proxy host.containers.internal:3333
}

docs.guirao.net {
	log {
		output file /var/log/caddy/paperless.log
	}
	import private
	reverse_proxy host.containers.internal:8000
}

maps.guirao.net {
	log {
		output file /var/log/caddy/dawarich.log
	}
	import private
	reverse_proxy host.containers.internal:3000
}

files.guirao.net {
	log {
		output file /var/log/caddy/files.log
	}
	import public
	basic_auth {
		user {$FILES_PASSWORD_HASH}
	}
	file_server {
		root /data/caddy/files
		browse
	}
}

mail.guirao.net,
mta-sts.guirao.net,
autoconfig.guirao.net,
autodiscover.guirao.net {
	reverse_proxy 127.0.0.1:8080 {
		transport http {
			proxy_protocol v2
		}
	}
	log {
		output file /var/log/caddy/stalwart.log
	}
}

http://, https:// {
	abort
}
